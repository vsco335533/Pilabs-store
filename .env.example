# App Settings
PROJECT_NAME="PiLabs Store"
API_V1_STR="/api/v1"
SECRET_KEY="replace-this-with-a-secure-random-key"
REFRESH_SECRET_KEY="replace-this-with-another-secure-random-key"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT="development"

# Database Configuration (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/appstore"
ASYNC_DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/appstore"

# Redis & Celery Configuration
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# CORS Origins (JSON List)
BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://localhost:8000", "http://localhost:8081", "exp://localhost:8081"]'

# Storage Directories
UPLOAD_DIR="./uploads"

# Admin Initial Seed Credentials
SUPERADMIN_EMAIL="superadmin@enterprise.com"
SUPERADMIN_PASSWORD="SuperSecurePassword123!"

# Brevo Configuration
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="capitalvsco@gmail.com"
BREVO_SENDER_NAME="Enterprise App Store"

